{
  "_comment": "Non-secret defaults. Secrets live in .env. Override via --env=staging|prod|dev.",

  "framework": {
    "name": "ASTRA-v2",
    "version": "2.0.0"
  },

  "browser": {
    "default": "chromium",
    "supported": ["chromium", "firefox", "webkit"],
    "headless": false,
    "slow_mo_ms": 0,
    "viewport": { "width": 1280, "height": 720 },
    "ignore_https_errors": true
  },

  "timeouts": {
    "action_ms": 15000,
    "navigation_ms": 30000,
    "expect_ms": 10000
  },

  "retry": {
    "max_attempts": 3,
    "backoff_seconds": [2, 4, 8]
  },

  "self_healing": {
    "enabled": true,
    "auto_apply_silent": true,
    "min_confidence": 0.75,
    "registry_path": "Data/locators/locator_registry.db",
    "model_path": "Prism_view/self_healing/ml/models/healer_model.onnx",
    "sklearn_model_path": "Prism_view/self_healing/ml/models/healer_model.pkl"
  },

  "shadow_coding": {
    "session_dir": "Prism_view/shadow_coding/sessions",
    "auto_assertions": true,
    "assertion_checkpoints": ["page_load", "click", "navigation", "popup_visible"]
  },

  "reporting": {
    "tool": "allure",
    "results_dir": "reports/allure-results",
    "attach_screenshots_on_failure": true,
    "attach_traces_on_failure": true,
    "attach_videos_on_failure": false
  },

  "notifications": {
    "enabled": true,
    "send_on": "every_run",
    "channels": ["slack", "teams", "email"]
  },

  "environments": {
    "mod":     { "base_url": "https://mrm.stg.freewheel.tv/",     "api_url": "https://mrm.stg.freewheel.tv/" },
    "stg": { "base_url": "https://mrm.stg.freewheel.tv/", "api_url": "https://mrm.stg.freewheel.tv/" },
    "prod":    { "base_url": "https://prod.example.com",    "api_url": "https://prod.example.com/api" }
  },

  "default_env": "stg"
}
