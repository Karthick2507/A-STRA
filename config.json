{
  "_comment": "PRISM standalone defaults. Plugin mode reads Prism_view/shadow_coding/prism_config.json (Batch 2). Secrets live in .env.",

  "framework": {
    "name": "PRISM",
    "version": "2.0.0"
  },

  "browser": {
    "default": "chromium",
    "supported": ["chromium", "firefox", "webkit"],
    "headless": false,
    "slow_mo_ms": 0,
    "viewport": { "width": 1280, "height": 720 }
  },

  "timeouts": {
    "action_ms": 15000,
    "navigation_ms": 30000,
    "expect_ms": 10000
  },

  "self_healing": {
    "enabled": true,
    "auto_apply_silent": true,
    "min_confidence": 0.75,
    "registry_path": "Data/locators/locator_registry.db",
    "model_path": "Prism_view/self_healing/ml/models/healer_model.onnx",
    "sklearn_path": "Prism_view/self_healing/ml/models/healer_model.pkl"
  },

  "shadow_coding": {
    "session_dir": "Prism_view/shadow_coding/sessions",
    "auto_assertions": true,
    "assertion_checkpoints": ["page_load", "click", "navigation", "popup_visible"],
    "style_profile_path": "Prism_view/shadow_coding/style_profile.json",
    "train_classifier_on_learn": true
  },

  "environments": {
    "dev":  { "base_url": "" },
    "stg":  { "base_url": "" },
    "prod": { "base_url": "" }
  },

  "default_env": "dev"
}
