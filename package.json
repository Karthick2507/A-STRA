{
  "name": "astar-test-framework",
  "version": "1.0.0",
  "description": "Autonomous A* Search Based UI, API & E2E Test Framework with Preflight Health Check",
  "main": "index.ts",
  "scripts": {
    "preflight": "ts-node preflight/healthCheck.orchestrator.ts",
    "test:ui": "ts-node runners/ui/uiTestRunner.ts",
    "test:api": "ts-node runners/api/apiTestRunner.ts",
    "test:e2e": "ts-node runners/e2e/e2eTestRunner.ts",
    "codegen:ui": "ts-node codegen/uiCodeGenerator.ts",
    "codegen:api": "ts-node codegen/apiCodeGenerator.ts",
    "full:run": "npm run preflight && npm run codegen:ui && npm run codegen:api && npm run test:e2e",
    "report:open": "open reports/preflight/preflightReport.html"
  },
  "dependencies": {
    "@playwright/test": "^1.43.0",
    "dotenv": "^16.4.5",
    "winston": "^3.13.0",
    "fs-extra": "^11.2.0",
    "chalk": "^4.1.2",
    "axios": "^1.6.8",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "ts-node": "^10.9.2",
    "@types/node": "^20.12.7",
    "@types/fs-extra": "^11.0.4",
    "@types/uuid": "^9.0.8"
  },
  "keywords": [
    "playwright",
    "astar",
    "test-automation",
    "ui-testing",
    "api-testing",
    "e2e",
    "data-driven",
    "autonomous-testing"
  ],
  "author": "Karthick",
  "license": "MIT"
}