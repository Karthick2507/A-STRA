{
  "schemaId": "api-registration",
  "version": "1.0.0",
  "target": "api",
  "description": "Customer registration REST API — full schema example",
  "endpoint": "https://mrm.stg.freewheel.tv/app/543761/advertising/agencies/create/",
  "method": "POST",
  "goalCondition": {
    "api": {
      "successCodes": [
        200,
        201
      ],
      "responseContains": "id"
    }
  },
  "astarConfig": {
    "maxIterations": 300,
    "heuristicWeight": 1,
    "goalTimeout": 10000,
    "allowPartialGoal": false
  },
  "sections": [
    {
      "sectionName": "personalInfo",
      "mandatory": true,
      "weight": 10,
      "label": "Personal Information",
      "fields": [
        {
          "name": "firstName",
          "type": "text",
          "weight": 9,
          "label": "First Name",
          "apiKey": "first_name",
          "validationRule": {
            "pattern": "^[a-zA-Z]{2,50}$",
            "minLength": 2,
            "maxLength": 50,
            "errorMessage": "first_name must be 2-50 alphabetic characters"
          },
          "dataHints": {
            "validSamples": [
              "Karthick",
              "Priya",
              "John",
              "Aisha"
            ],
            "invalidSamples": [
              "A",
              "123Name",
              ""
            ]
          }
        },
        {
          "name": "lastName",
          "type": "text",
          "weight": 9,
          "label": "Last Name",
          "apiKey": "last_name",
          "validationRule": {
            "pattern": "^[a-zA-Z]{2,50}$",
            "minLength": 2,
            "maxLength": 50,
            "errorMessage": "last_name must be 2-50 alphabetic characters"
          },
          "dataHints": {
            "validSamples": [
              "Kumar",
              "Smith",
              "Raj",
              "Chen"
            ],
            "invalidSamples": [
              "",
              "1",
              "A"
            ]
          }
        },
        {
          "name": "email",
          "type": "email",
          "weight": 10,
          "label": "Email Address",
          "apiKey": "email",
          "validationRule": {
            "pattern": "^[\\w.-]+@[\\w.-]+\\.\\w{2,}$",
            "errorMessage": "email must be a valid email address"
          },
          "dataHints": {
            "validSamples": [
              "test@astra.com",
              "user@example.com",
              "qa@freewheel.tv"
            ],
            "invalidSamples": [
              "notanemail",
              "missing@",
              "@nodomain"
            ],
            "format": "email",
            "unique": true
          }
        },
        {
          "name": "phone",
          "type": "phone",
          "weight": 7,
          "label": "Mobile Number",
          "apiKey": "phone_number",
          "validationRule": {
            "pattern": "^[6-9]\\d{9}$",
            "errorMessage": "phone_number must be a valid 10-digit Indian mobile number"
          },
          "dataHints": {
            "validSamples": [
              "9876543210",
              "8123456789",
              "7001234567"
            ],
            "invalidSamples": [
              "12345",
              "0123456789",
              "abcdefghij"
            ],
            "locale": "en-IN"
          }
        }
      ]
    },
    {
      "sectionName": "address",
      "mandatory": true,
      "weight": 8,
      "label": "Address",
      "fields": [
        {
          "name": "address",
          "type": "text",
          "weight": 8,
          "label": "Address Object",
          "apiKey": "address",
          "children": [
            {
              "name": "street",
              "type": "text",
              "weight": 8,
              "label": "Street",
              "apiKey": "street",
              "validationRule": {
                "minLength": 3,
                "maxLength": 100,
                "errorMessage": "address.street is required"
              },
              "dataHints": {
                "validSamples": [
                  "12 Main Street",
                  "45 Gandhi Road",
                  "Plot 7 Lake View"
                ],
                "invalidSamples": [
                  "",
                  "A"
                ]
              }
            },
            {
              "name": "city",
              "type": "text",
              "weight": 8,
              "label": "City",
              "apiKey": "city",
              "validationRule": {
                "pattern": "^[a-zA-Z\\s]{2,50}$",
                "errorMessage": "address.city must be a valid city name"
              },
              "dataHints": {
                "validSamples": [
                  "Chennai",
                  "Bangalore",
                  "Mumbai",
                  "Hyderabad"
                ],
                "invalidSamples": [
                  "",
                  "12345"
                ]
              }
            },
            {
              "name": "state",
              "type": "text",
              "weight": 7,
              "label": "State",
              "apiKey": "state",
              "validValues": [
                "Tamil Nadu",
                "Karnataka",
                "Maharashtra",
                "Delhi",
                "Telangana",
                "Kerala"
              ],
              "dataHints": {
                "validSamples": [
                  "Tamil Nadu",
                  "Karnataka"
                ],
                "invalidSamples": [
                  "InvalidState",
                  "12345"
                ]
              }
            },
            {
              "name": "pincode",
              "type": "text",
              "weight": 7,
              "label": "Pincode",
              "apiKey": "pincode",
              "validationRule": {
                "pattern": "^[1-9][0-9]{5}$",
                "errorMessage": "address.pincode must be a valid 6-digit pincode"
              },
              "dataHints": {
                "validSamples": [
                  "600001",
                  "560001",
                  "400001"
                ],
                "invalidSamples": [
                  "12345",
                  "000000",
                  "abcdef"
                ]
              }
            },
            {
              "name": "country",
              "type": "text",
              "weight": 5,
              "label": "Country",
              "apiKey": "country",
              "validValues": [
                "India",
                "USA",
                "UK",
                "Australia",
                "Singapore"
              ],
              "dataHints": {
                "validSamples": [
                  "India"
                ],
                "invalidSamples": [
                  "",
                  "XYZ"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "sectionName": "credentials",
      "mandatory": true,
      "weight": 10,
      "label": "Credentials",
      "fields": [
        {
          "name": "username",
          "type": "text",
          "weight": 10,
          "label": "Username",
          "apiKey": "username",
          "validationRule": {
            "pattern": "^[a-zA-Z0-9_]{4,20}$",
            "minLength": 4,
            "maxLength": 20,
            "errorMessage": "username must be 4-20 alphanumeric characters or underscore"
          },
          "dataHints": {
            "validSamples": [
              "astra_user",
              "test_qa_01",
              "karthick_001"
            ],
            "invalidSamples": [
              "ab",
              "user name",
              "aaaaaaaaaaaaaaaaaaaaa"
            ],
            "unique": true
          }
        },
        {
          "name": "password",
          "type": "password",
          "weight": 10,
          "label": "Password",
          "apiKey": "password",
          "validationRule": {
            "pattern": "^(?=.*[A-Z])(?=.*\\d)(?=.*[@$!%*?&])[A-Za-z\\d@$!%*?&]{8,}$",
            "minLength": 8,
            "errorMessage": "password must have 1 uppercase, 1 number, 1 special char, min 8 chars"
          },
          "dataHints": {
            "validSamples": [
              "Test@1234",
              "Secure#Pass9",
              "Astra@2024!"
            ],
            "invalidSamples": [
              "weak",
              "12345678",
              "NoSpecial1"
            ]
          }
        }
      ]
    },
    {
      "sectionName": "metadata",
      "mandatory": false,
      "weight": 3,
      "label": "Optional Metadata",
      "fields": [
        {
          "name": "gender",
          "type": "text",
          "weight": 3,
          "label": "Gender",
          "apiKey": "gender",
          "validValues": [
            "male",
            "female",
            "non_binary",
            "prefer_not_to_say"
          ],
          "dataHints": {
            "validSamples": [
              "male",
              "female"
            ],
            "invalidSamples": [
              "INVALID_GENDER"
            ]
          }
        },
        {
          "name": "dateOfBirth",
          "type": "date",
          "weight": 3,
          "label": "Date of Birth",
          "apiKey": "date_of_birth",
          "validationRule": {
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
            "errorMessage": "date_of_birth must be in YYYY-MM-DD format"
          },
          "dataHints": {
            "validSamples": [
              "1995-06-15",
              "2000-01-01",
              "1988-03-22"
            ],
            "invalidSamples": [
              "32-13-2000",
              "notadate",
              ""
            ],
            "format": "YYYY-MM-DD"
          }
        },
        {
          "name": "newsletterOptIn",
          "type": "checkbox",
          "weight": 2,
          "label": "Newsletter Opt-In",
          "apiKey": "newsletter_opt_in",
          "validValues": [
            "true",
            "false"
          ],
          "dataHints": {
            "validSamples": [
              "true"
            ],
            "invalidSamples": [
              "yes",
              "1"
            ]
          }
        },
        {
          "name": "referralCode",
          "type": "text",
          "weight": 2,
          "label": "Referral Code",
          "apiKey": "referral_code",
          "validationRule": {
            "pattern": "^[A-Z0-9]{6,10}$",
            "errorMessage": "referral_code must be 6-10 uppercase alphanumeric characters"
          },
          "dataHints": {
            "validSamples": [
              "ASTRA001",
              "REF2024AB"
            ],
            "invalidSamples": [
              "short",
              "toolongcodehere123",
              "lowercase"
            ]
          }
        }
      ]
    }
  ]
}
