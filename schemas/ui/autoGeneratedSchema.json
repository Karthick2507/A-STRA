{
  "schemaId": "ui-registration-reconciled",
  "version": "1.0.0",
  "target": "ui",
  "description": "Customer registration form — full hierarchical schema example",
  "goalCondition": {
    "ui": {
      "successSelector": ".success-message, .alert-success, [data-success]",
      "successText": "successfully",
      "urlContains": "/success",
      "waitForSelector": "form"
    }
  },
  "astarConfig": {
    "maxIterations": 500,
    "heuristicWeight": 1,
    "goalTimeout": 30000,
    "allowPartialGoal": false
  },
  "sections": [
    {
      "sectionName": "default",
      "mandatory": true,
      "weight": 10,
      "label": "Default",
      "stepIndex": 0,
      "fields": [
        {
          "name": "login",
          "type": "text",
          "weight": 9,
          "label": "Login Name",
          "selector": "#login",
          "dataHints": {
            "validSamples": [
              "test_login_value",
              "astra_login"
            ],
            "invalidSamples": [
              "",
              " "
            ]
          }
        },
        {
          "name": "password",
          "type": "password",
          "weight": 9,
          "label": "Password",
          "selector": "#password",
          "validationRule": {
            "pattern": "^(?=.*[A-Z])(?=.*\\d)(?=.*[@$!%*?&])[A-Za-z\\d@$!%*?&]{8,}$",
            "minLength": 8,
            "errorMessage": "Min 8 chars with 1 uppercase, 1 number, 1 special char"
          },
          "dataHints": {
            "validSamples": [
              "Test@1234",
              "Secure#Pass9",
              "Astra@2024!"
            ],
            "invalidSamples": [
              "weak",
              "12345678",
              "NoSpecial1"
            ]
          }
        }
      ]
    }
  ]
}
