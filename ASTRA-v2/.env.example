# ASTRA-v2 .env template
#
# Copy this file to .env and fill in values. NEVER commit the real .env.

# ─── Environment selection (overrides config.json default_env) ─────────────
ASTRA_ENV=dev

# ─── Application credentials ─────────────────────────────────────────────────
APP_USERNAME=your_username
APP_PASSWORD=your_password

# ─── API authentication (use whichever applies) ──────────────────────────────
BEARER_TOKEN=
API_KEY=
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=

# ─── Browser overrides (optional, override config.json) ──────────────────────
# BROWSER=chromium
# HEADLESS=false
# SLOW_MO_MS=0

# ─── Notification webhooks ───────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=

# ─── Email notifications (SMTP) ──────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=astra@example.com
SMTP_TO=team@example.com,qa@example.com
