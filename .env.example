# ASTRA Framework Environment Configuration

# Application URLs
BASE_URL=https://your-app.com
LOGIN_URL=https://your-app.com/login
TARGET_PAGE_URL=https://your-app.com/register

# Credentials
APP_USERNAME=your_username
APP_PASSWORD=your_password

# Bearer token (auto-populated by preflight)
BEARER_TOKEN=

# Health check toggle (true = run preflight, false = skip)
HEALTH_CHECK=true

# Browser config
BROWSER=chromium
HEADLESS=false
