# ─── Your Application ─────────────────────────────
BASE_URL=https://your-app.com
LOGIN_URL=https://your-app.com/login
TARGET_PAGE_URL=https://your-app.com/your-form
APP_USERNAME=your-username@email.com
APP_PASSWORD=your-password

# ─── Health Check ─────────────────────────────────
HEALTH_CHECK=TRUE

# ─── Individual Analyser Toggles ──────────────────
DOM_ANALYSER_ENABLED=true
BEARER_TOKEN_ANALYSER_ENABLED=true
NETWORK_INTERCEPTOR_ENABLED=true
ANTI_BOT_ANALYSER_ENABLED=true

# ─── Bearer Token (auto-populated by preflight) ───
BEARER_TOKEN=

# ─── Browser Settings ─────────────────────────────
BROWSER=chromium
HEADLESS=true
SLOW_MO=0

# ─── A* Engine ────────────────────────────────────
ASTAR_MAX_ITERATIONS=1000
ASTAR_HEURISTIC_WEIGHT=1.0
ASTAR_GOAL_TIMEOUT=30000

# ─── API Settings ─────────────────────────────────
API_BASE_URL=https://your-app.com
API_TIMEOUT=10000
TOKEN_TYPE=Bearer

# ─── Reports ──────────────────────────────────────
REPORT_FORMAT=both
TEST_REPORT_DIR=reports/testResults
REPORT_OUTPUT_DIR=reports/preflight
